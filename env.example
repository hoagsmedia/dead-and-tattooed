# Better Auth Configuration
BETTER_AUTH_SECRET=your-secret-key-here-generate-with-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:5173

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Stripe Webhook Secret
# For local development: Get this by running `stripe listen --forward-to localhost:5173/api/stripe/webhook`
# The CLI will output a webhook signing secret (starts with whsec_) - copy it here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# Cloudflare R2 Configuration
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=dead-and-tattooed

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/dead_and_tattooed
DATABASE_SSL=false

# Email (password resets, order notifications) — Resend account for this store
RESEND_API_KEY=
RESEND_FROM="Dead & Tattooed <no-reply@deadandtattooed.com>"

# Seller allowlist — only these emails may use /dashboard and uploads
ADMIN_EMAILS=
